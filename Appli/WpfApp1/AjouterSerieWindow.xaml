<Window x:Class="GymApp.AjouterSerieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter des séries" Height="Auto" Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ajouter des séries" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource AppTextMain}"/>

        <TextBlock Grid.Row="1" Text="Exercice *" Foreground="{DynamicResource AppTextSub}" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="2" x:Name="ComboExercice" Height="34" Margin="0,0,0,16" DisplayMemberPath="Nom"
                  Background="{DynamicResource AppCardBg}" Foreground="{DynamicResource AppTextMain}"/>

        <TextBlock Grid.Row="3" Text="Séries" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextMain}"/>

        <Grid Grid.Row="4" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Répétitions" Foreground="{DynamicResource AppTextSub}" FontSize="11" Margin="5,0,0,0"/>
            <TextBlock Grid.Column="1" Text="Poids (kg)" Foreground="{DynamicResource AppTextSub}" FontSize="11"/>
        </Grid>

        <ItemsControl Grid.Row="5" x:Name="ListeSeriesControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="32" Padding="8,4" Text="{Binding Repetitions}" 
                                 Background="{DynamicResource AppCardBg}" Foreground="{DynamicResource AppTextMain}" BorderBrush="{DynamicResource AppTextSub}" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="1" Height="32" Padding="8,4" Text="{Binding Poids}" 
                                 Background="{DynamicResource AppCardBg}" Foreground="{DynamicResource AppTextMain}" BorderBrush="{DynamicResource AppTextSub}" Margin="0,0,6,0"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="6" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Annuler" Width="90" Height="35" Margin="0,0,10,0" Click="BtnAnnuler_Click" 
                    Background="{DynamicResource AppCardBg}" Foreground="{DynamicResource AppTextMain}" BorderBrush="{DynamicResource AppTextSub}"/>
            <Button Grid.Column="1" Content="Confirmer" Width="90" Height="35" Background="#E94560" Foreground="White" BorderThickness="0" Click="BtnConfirmer_Click"/>
        </Grid>
    </Grid>
</Window>