<Window x:Class="GymApp.AjouterSerieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter des séries à la séance" Height="Auto" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="25">
        <TextBlock Text="Ajouter des séries" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Choix de l'exercice -->
        <TextBlock Text="Exercice *" Foreground="#555" Margin="0,0,0,4"/>
        <ComboBox x:Name="ComboExercice" Height="34" Margin="0,0,0,16"
                  DisplayMemberPath="Nom"/>

        <!-- Séries -->
        <TextBlock Text="Séries" FontWeight="Bold" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="170*"/>
                <ColumnDefinition Width="179*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Répétitions" Foreground="#888"
                       FontSize="11" HorizontalAlignment="Left" Margin="53,0,0,0"/>
            <TextBlock Grid.Column="2" Text="Poids (kg)" Foreground="#888"
                       FontSize="11" HorizontalAlignment="Center"/>
        </Grid>

        <ItemsControl x:Name="ListeSeriesControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="32" Padding="8,4"
                                 Text="{Binding Repetitions, UpdateSourceTrigger=PropertyChanged}"
                                 BorderBrush="#DDD" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="1" Height="32" Padding="8,4"
                                 Text="{Binding Poids, UpdateSourceTrigger=PropertyChanged}"
                                 BorderBrush="#DDD" Margin="0,0,6,0"/>
                        
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        



        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Width="90" Height="35" Margin="0,0,10,0"
                    Click="BtnAnnuler_Click" Background="#EEE" BorderThickness="0"/>
            <Button Content="Confirmer" Width="90" Height="35"
                    Background="#E94560" Foreground="White"
                    BorderThickness="0" Click="BtnConfirmer_Click"/>
        </StackPanel>
    </StackPanel>
</Window>