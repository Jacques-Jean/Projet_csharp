<Window x:Class="GymApp.SupprimerExerciceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Supprimer un exercice" Height="200" Width="350" 
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">
    <StackPanel Margin="20">
        <TextBlock Text="Choisir l'exercice à supprimer :" 
                   Margin="0,0,0,10" FontWeight="Bold" FontSize="14"/>

        <!-- Le ComboBox pour choisir l'exercice -->
        <ComboBox x:Name="ComboExercices" 
                  DisplayMemberPath="Nom" 
                  Height="35" VerticalContentAlignment="Center"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="Annuler" Width="80" Height="30" Margin="5" 
                    IsCancel="True" Background="#CCC" BorderThickness="0"/>
            <Button Content="Supprimer" Width="90" Height="30" Margin="5" 
                    Background="#E94560" Foreground="White" BorderThickness="0"
                    Click="BtnConfirmer_Click"/>
        </StackPanel>
    </StackPanel>
</Window>