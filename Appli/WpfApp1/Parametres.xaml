<Window x:Class="GymApp.Parametres"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Paramètres" FontSize="16" FontWeight="Bold"/>

        <!-- Mode nuit -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Thème" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioJour" Content="Mode jour"
                             Margin="0,0,20,0" GroupName="Theme"/>
                <RadioButton x:Name="RadioNuit" Content="Mode nuit"
                             GroupName="Theme"/>
            </StackPanel>
        </StackPanel>

        <!-- Unité de poids -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Unité de poids" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioKg"  Content="Kilogrammes (kg)"
                             Margin="0,0,20,0" GroupName="Poids"/>
                <RadioButton x:Name="RadioLbs" Content="Livres (lbs)"
                             GroupName="Poids"/>
            </StackPanel>
        </StackPanel>

        <!-- Boutons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler"   Width="90" Height="35" Margin="0,0,10,0"
                    Background="#EEE" BorderThickness="0" Click="BtnAnnuler_Click"/>
            <Button Content="Confirmer" Width="90" Height="35"
                    Background="#1A1A2E" Foreground="White"
                    BorderThickness="0" Click="BtnConfirmer_Click"/>
        </StackPanel>
    </Grid>
</Window>