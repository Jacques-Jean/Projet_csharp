<Window x:Class="GymApp.Parametres"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Paramètres" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextMain}"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Thème" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextMain}"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioJour" Content="Mode jour" Margin="0,0,20,0" GroupName="Theme" Foreground="{DynamicResource AppTextSub}"/>
                <RadioButton x:Name="RadioNuit" Content="Mode nuit" GroupName="Theme" Foreground="{DynamicResource AppTextSub}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Unité de poids" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextMain}"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioKg" Content="Kilogrammes (kg)" Margin="0,0,20,0" GroupName="Poids" Foreground="{DynamicResource AppTextSub}"/>
                <RadioButton x:Name="RadioLbs" Content="Livres (lbs)" GroupName="Poids" Foreground="{DynamicResource AppTextSub}"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="6" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Annuler" Width="90" Height="35" Margin="0,0,10,0" 
                    Background="{DynamicResource AppCardBg}" Foreground="{DynamicResource AppTextMain}" BorderBrush="{DynamicResource AppTextSub}" Click="BtnAnnuler_Click"/>
            <Button Grid.Column="1" Content="Confirmer" Width="90" Height="35" 
                    Background="#1A1A2E" Foreground="White" BorderThickness="0" Click="BtnConfirmer_Click"/>
        </Grid>
    </Grid>
</Window>