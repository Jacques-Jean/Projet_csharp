<Window x:Class="GymApp.AjouterExerciceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter un exercice" Height="Auto" Width="440" 
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Nouvel exercice" FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20" Foreground="{DynamicResource AppTextMain}"/>

        <TextBlock Grid.Row="1" Text="Nom *" Margin="0,0,0,4" 
                   Foreground="{DynamicResource AppTextSub}"/>
        <TextBox Grid.Row="2" x:Name="TxtNom" Height="34" Padding="8,6" 
                 Margin="0,0,0,12"
                 Background="{DynamicResource AppCardBg}" 
                 Foreground="{DynamicResource AppTextMain}"
                 BorderBrush="{DynamicResource AppTextSub}" BorderThickness="1"/>

        <TextBlock Grid.Row="3" Text="Muscle ciblé *" Margin="0,0,0,4" 
                   Foreground="{DynamicResource AppTextSub}"/>
        <TextBox Grid.Row="4" x:Name="TxtMuscle" Height="34" Padding="8,6" 
                 Margin="0,0,0,12"
                 Background="{DynamicResource AppCardBg}" 
                 Foreground="{DynamicResource AppTextMain}"
                 BorderBrush="{DynamicResource AppTextSub}" BorderThickness="1"/>

        <TextBlock Grid.Row="5" Text="Description" Margin="0,0,0,4" 
                   Foreground="{DynamicResource AppTextSub}"/>
        <TextBox Grid.Row="6" x:Name="TxtDescription" Height="80" Padding="8,6" 
                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,16"
                 Background="{DynamicResource AppCardBg}" 
                 Foreground="{DynamicResource AppTextMain}"
                 BorderBrush="{DynamicResource AppTextSub}" BorderThickness="1"/>

        <ItemsControl Grid.Row="7" x:Name="ListeSeriesControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="8" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Annuler" Width="100" Height="35" Margin="0,0,10,0"
                    Click="BtnAnnuler_Click" 
                    Background="{DynamicResource AppCardBg}" 
                    Foreground="{DynamicResource AppTextMain}"
                    BorderBrush="{DynamicResource AppTextSub}" BorderThickness="1"/>

            <Button Grid.Column="1" Content="Ajouter" Width="100" Height="35"
                    Background="#E94560" Foreground="White"
                    BorderThickness="0" Click="BtnAjouter_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>