<Window x:Class="GymApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GymApp"
        Title="Gym Management System" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:CouleurSeanceConverter x:Key="CouleurSeanceConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1A1A2E">
            <StackPanel Margin="10">
                <TextBlock Text="GYM PRO" Foreground="White" FontSize="20"
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,30"/>
                <Button Content="Séances" Click="BtnSeances_Click"
                        Background="#E94560" Foreground="White"
                        Height="40" Margin="0,5" BorderThickness="0"/>
                <Button Content="Exercices" Click="BtnExercices_Click"
                        Background="#E94560" Foreground="White"
                        Height="40" Margin="0,5" BorderThickness="0"/>
                <Button Content="Paramètres" Click="BtnParametres_Click"
                        Background="#E94560" Foreground="White"
                        Height="40" Margin="0,5" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- CONTENU -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{DynamicResource AppCardBg}"
                    BorderBrush="#EEE" BorderThickness="0,0,0,1">
                <TextBlock x:Name="TxtTitrePage" Text="Séances"
                           VerticalAlignment="Center" Margin="20,0" FontSize="18"
                           Foreground="{DynamicResource AppTextMain}"/>
            </Border>

            <!-- CONTENU PRINCIPAL -->
            <Border Grid.Row="1" Background="{DynamicResource AppBackground}">
                <ScrollViewer Margin="20">
                    <StackPanel>

                        <!-- VUE SÉANCES -->
                        <StackPanel x:Name="SeancesPanel">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1" Content="- Supprimer"
                                        Width="90" Height="32" Margin="5"
                                        Background="#E94560" Foreground="White"
                                        BorderThickness="0" Click="BtnSupprimerSeance_Click"/>
                                <Button Grid.Column="2" Content="+ Ajouter"
                                        Width="90" Height="32" Margin="5"
                                        Background="#E94560" Foreground="White"
                                        BorderThickness="0" Click="BtnAjouterSeance_Click"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Seances}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource AppCardBg}"
                                                CornerRadius="8" Padding="15" Margin="0,0,0,12"
                                                BorderThickness="3"
                                                BorderBrush="{Binding ListeSeries.Count,
                                                              Converter={StaticResource CouleurSeanceConverter}}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <!-- Header séance -->
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding Nom}"
                                                               FontSize="15" FontWeight="Bold"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource AppTextMain}"/>
                                                    <Button Content="Modifier"
                                                            HorizontalAlignment="Right"
                                                            Width="90" Height="28"
                                                            Background="#1A1A2E" Foreground="White"
                                                            BorderThickness="0"
                                                            Tag="{Binding}"
                                                            Click="BtnModifierSeriesSeance_Click"/>
                                                </Grid>

                                                <!-- Liste des séries -->
                                                <ItemsControl ItemsSource="{Binding ListeSeries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,5">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="200"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"></TextBlock>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding exercice.Nom}"
                                                                           Foreground="{DynamicResource AppTextSub}"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Repetitions, StringFormat='{}{0} reps'}"
                                                                           Foreground="{DynamicResource AppTextSub}"
                                                                           TextAlignment="Center"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Foreground="{DynamicResource AppTextSub}"
                                                                           TextAlignment="Right">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0} {1}">
                                                                            <Binding Path="Poids"/>
                                                                            <Binding Path="UnitePoids"
                                                                                     Source="{x:Static local:ParametresService.Instance}"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- VUE EXERCICES -->
                        <StackPanel x:Name="ExercicesPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1" Content="- Supprimer"
                                        Width="90" Height="32" Margin="5"
                                        Background="#E94560" Foreground="White"
                                        BorderThickness="0" Click="BtnSupprimerExercice_Click"/>
                                <Button Grid.Column="2" Content="+ Ajouter"
                                        Width="90" Height="32" Margin="5"
                                        Background="#E94560" Foreground="White"
                                        BorderThickness="0" Click="BtnAjouterExercice_Click"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Exercices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource AppCardBg}"
                                                CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Nom}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource AppTextMain}"/>
                                                <TextBlock Text="{Binding FocusedMuscle}"
                                                           Foreground="#E94560" Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{DynamicResource AppTextSub}"
                                                           Margin="0,5,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>